datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Department {
  id               String            @id @default(cuid())
  name             String
  code             String
  headName         String?
  employeeCount    Int               @default(0)
  status           String            @default("active")
  carbonTarget     Float             @default(10.0)
  carbonTx         CarbonTransaction[]
  employees        Employee[]
  complianceIssues ComplianceIssue[]
  spendingRecords  SpendingRecord[]
}

model Employee {
  id               String                  @id @default(cuid())
  name             String
  email            String                  @unique
  passwordHash     String
  role             String                  @default("employee") // "employee" | "manager" | "officer"
  gender           String                  @default("Prefer not to say")
  ethnicity        String                  @default("Prefer not to say")
  departmentId     String
  department       Department              @relation(fields: [departmentId], references: [id])
  xp               Int                     @default(0)
  points           Int                     @default(0)
  participations   EmployeeParticipation[]
  challengeParts   ChallengeParticipation[]
  badges           EmployeeBadge[]
  acknowledgements PolicyAcknowledgement[]
  trainings        EmployeeTraining[]
}

model Category {
  id     String @id @default(cuid())
  name   String
  type   String // "CSR" | "CHALLENGE"
  status String @default("active")
}

model EmissionFactor {
  id           String              @id @default(cuid())
  name         String
  unit         String
  co2eValue    Float
  transactions CarbonTransaction[]
}

model CarbonTransaction {
  id               String         @id @default(cuid())
  departmentId     String
  department       Department     @relation(fields: [departmentId], references: [id])
  emissionFactorId String
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id])
  quantity         Float
  co2eTotal        Float
  source           String         @default("manual") // manual | auto
  date             DateTime       @default(now())
}

model CSRActivity {
  id             String                  @id @default(cuid())
  title          String
  categoryId     String?
  description    String?
  date           DateTime                @default(now())
  participations EmployeeParticipation[]
}

model EmployeeParticipation {
  id             String      @id @default(cuid())
  employeeId     String
  employee       Employee    @relation(fields: [employeeId], references: [id])
  activityId     String
  activity       CSRActivity @relation(fields: [activityId], references: [id])
  proofUrl       String?
  approvalStatus String      @default("pending") // pending | approved | rejected
  pointsEarned   Int         @default(0)
  completedAt    DateTime?
}

model Challenge {
  id             String                   @id @default(cuid())
  title          String
  categoryId     String?
  description    String?
  xp             Int
  difficulty     String                   @default("medium")
  status         String                   @default("draft") // draft | active | under_review | completed | archived
  deadline       DateTime?
  participations ChallengeParticipation[]
}

model ChallengeParticipation {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  progress    Int       @default(0)
  proofUrl    String?
  approval    String    @default("pending")
  xpAwarded   Int       @default(0)
}

model Badge {
  id          String          @id @default(cuid())
  name        String
  description String?
  unlockRule  String          // simple JSON string e.g. {"xpGte":100}
  icon        String?
  employees   EmployeeBadge[]
}

model EmployeeBadge {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  awardedAt  DateTime @default(now())
}

model ESGPolicy {
  id               String                  @id @default(cuid())
  title            String
  body             String?
  acknowledgements PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id             String    @id @default(cuid())
  policyId       String
  policy         ESGPolicy @relation(fields: [policyId], references: [id])
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  acknowledgedAt DateTime  @default(now())
}

model ComplianceIssue {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  severity     String     // low | medium | high | critical
  description  String
  owner        String
  dueDate      DateTime
  status       String     @default("open") // open | resolved
}

model AppConfig {
  id                  String  @id @default("global")
  autoEmissionCalc    Boolean @default(false)
  evidenceRequired    Boolean @default(true)
  badgeAutoAward      Boolean @default(true)
  complianceEmailAlert Boolean @default(false)
  envWeight           Float   @default(0.4)
  socialWeight        Float   @default(0.3)
  govWeight           Float   @default(0.3)
  
  // Notification system switches
  notifyCompliance    Boolean @default(true)
  notifyApproval      Boolean @default(true)
  notifyPolicyReminder Boolean @default(true)
  notifyBadgeUnlock   Boolean @default(true)
}

model Reward {
  id             String   @id @default(cuid())
  name           String
  description    String?
  pointsRequired Int
  stock          Int
  status         String   @default("active") // active | out_of_stock
}

model SpendingRecord {
  id           String     @id @default(cuid())
  type         String     // "purchase" | "manufacturing" | "expense" | "fleet"
  description  String
  amount       Float      // spending in USD
  quantity     Float      // physical quantity
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  date         DateTime   @default(now())
}

model TrainingCourse {
  id          String             @id @default(cuid())
  name        String
  description String?
  xp          Int
  status      String             @default("active")
  completions EmployeeTraining[]
}

model EmployeeTraining {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])
  trainingId  String
  training    TrainingCourse @relation(fields: [trainingId], references: [id])
  completedAt DateTime       @default(now())
}

model Audit {
  id          String   @id @default(cuid())
  title       String
  description String?
  auditor     String
  date        DateTime @default(now())
  status      String   @default("pending") // pending | passed | failed
  findings    String?
}
